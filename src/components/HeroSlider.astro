---
import { Image } from 'astro:assets';

interface Props {
  slides: any[];
}

const { slides = [] } = Astro.props;
const heroSlides = slides;
---

{/* Container Luar untuk membatasi lebar & memberi jarak dari Navbar */}
<div class="hero-wrapper container">
    <section class="hero-slider-container">
      {heroSlides.length > 0 ? (
        <>
            {/* --- LIST SLIDE --- */}
            {heroSlides.map((item, index) => (
                <div class={`hero-slide ${index === 0 ? 'active' : ''}`} data-index={index}>
                    
                    {/* Layer 1: Background Image dengan Optimasi Astro */}
                    <div class="slide-bg">
                        {item.cover_url ? (
                            <Image 
                                src={item.cover_url} 
                                alt={item.title} 
                                width={1200}
                                height={600}
                                format="webp"
                                quality="mid"
                                loading={index === 0 ? "eager" : "lazy"} 
                                class="hero-img"
                            />
                        ) : (
                            <img src="https://placehold.co/1200x600" alt="Placeholder" class="hero-img" />
                        )}
                        <div class="overlay-gradient"></div>
                    </div>

                    {/* Layer 2: Konten Teks */}
                    <div class="slide-content-layer">
                        <div class="content-box">
                            {/* Kategori Badge (MERAH) */}
                            {item.article_categories?.[0]?.categories?.name && (
                                <span class="slide-badge">
                                    {item.article_categories[0].categories.name}
                                </span>
                            )}
                            
                            <h2 class="slide-title">
                                <a href={`/news/${item.slug}`}>{item.title}</a>
                            </h2>
                            
                            <div class="slide-meta">
                                <span class="author">Oleh {item.profiles?.full_name || 'Redaksi'}</span>
                                <span class="divider">•</span>
                                <span class="date">
                                    {new Date(item.created_at).toLocaleDateString('id-ID', { 
                                        day: 'numeric', month: 'long', year: 'numeric' 
                                    })}
                                </span>
                            </div>

                            <a href={`/berita/${item.slug}`} class="btn-read-hero">
                                Baca Selengkapnya
                            </a>
                        </div>
                    </div>
                </div>
            ))}

            {/* --- NAVIGASI DOTS --- */}
            <div class="slider-dots">
                {heroSlides.map((_, index) => (
                    <button 
                        class={`dot ${index === 0 ? 'active' : ''}`} 
                        data-index={index} 
                        aria-label={`Slide ${index + 1}`}
                    ></button>
                ))}
            </div>
        </>
      ) : (
        <div class="empty-hero">
            <h3>Belum ada berita headline.</h3>
        </div>
      )}
    </section>
</div>

<script>
    document.addEventListener('astro:page-load', () => {
        const slides = document.querySelectorAll('.hero-slide');
        const dots = document.querySelectorAll('.slider-dots .dot');
        
        if (slides.length === 0) return;

        let currentIndex = 0;
        let interval: ReturnType<typeof setInterval>;
        const INTERVAL_TIME = 5000; 

        function showSlide(index: number) {
            slides.forEach(s => s.classList.remove('active'));
            dots.forEach(d => d.classList.remove('active'));

            if(slides[index]) slides[index].classList.add('active');
            if(dots[index]) dots[index].classList.add('active');
            currentIndex = index;
        }

        function nextSlide() {
            let newIndex = currentIndex + 1;
            if (newIndex >= slides.length) newIndex = 0;
            showSlide(newIndex);
        }

        function startAutoPlay() {
            if (interval) clearInterval(interval);
            interval = setInterval(nextSlide, INTERVAL_TIME);
        }

        function resetTimer() {
            clearInterval(interval);
            startAutoPlay();
        }

        dots.forEach(dot => {
            dot.addEventListener('click', (e) => {
                const target = e.target as HTMLElement;
                const index = parseInt(target.getAttribute('data-index') || '0');
                showSlide(index);
                resetTimer();
            });
        });

        startAutoPlay();
    });
</script>

<style>
    /* --- WRAPPER AGAR RAPI & TIDAK KEPENTOK NAVBAR --- */
    .hero-wrapper.container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 20px;
        /* Ini kunci agar tidak ketindih Navbar (Sesuaikan pixelnya jika masih kurang turun) */
        margin-top: 30px; 
        margin-bottom: 40px;
    }

    /* --- SLIDER CONTAINER (ROUNDED) --- */
    .hero-slider-container {
        position: relative;
        width: 100%;
        height: 500px; /* Tinggi proporsional */
        background: #000;
        /* Rounding Desain Language */
        border-radius: 24px; 
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.15); /* Shadow halus biar pop-up */
    }

    /* --- SLIDE ITEM --- */
    .hero-slide {
        position: absolute;
        inset: 0;
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.8s ease-in-out, visibility 0.8s;
        z-index: 1;
    }

    .hero-slide.active { opacity: 1; visibility: visible; z-index: 2; }

    /* --- BACKGROUND --- */
    .slide-bg { position: absolute; inset: 0; z-index: -1; }
    .slide-bg img {
        width: 100%; height: 100%; object-fit: cover;
        transform: scale(1); transition: transform 6s ease;
    }
    .hero-slide.active .slide-bg img { transform: scale(1.08); }

    /* Gradient lebih halus & modern */
    .overlay-gradient {
        position: absolute; inset: 0;
        background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.4) 60%, rgba(0,0,0,0.1) 100%);
    }

    /* --- CONTENT --- */
    .slide-content-layer {
        position: absolute;
        inset: 0;
        z-index: 10;
        display: flex;
        align-items: flex-end; /* Text di bawah */
        padding: 40px 50px;
    }

    .content-box {
        max-width: 750px;
        color: white;
        transform: translateY(20px); opacity: 0;
        transition: all 0.8s ease 0.3s;
    }

    .hero-slide.active .content-box { transform: translateY(0); opacity: 1; }

    /* --- BADGE MERAH --- */
    .slide-badge {
        display: inline-block;
        background: #dc2626; /* MERAH CABE */
        color: white;
        padding: 6px 14px;
        border-radius: 8px; /* Rounded dikit */
        font-size: 0.8rem;
        font-weight: 550;
        text-transform: uppercase;
        margin-bottom: 16px;
        letter-spacing: 0.5px;
        box-shadow: 0 4px 10px rgba(220, 38, 38, 0.3);
    }

    .slide-title {
        font-size: 2.5rem;
        font-weight: 600;
        line-height: 1.2;
        margin: 0 0 15px 0;
        text-shadow: 0 2px 10px rgba(0,0,0,0.5);
    }

    .slide-title a { color: white; text-decoration: none; transition: color 0.3s; }
    .slide-title a:hover { color: #fca5a5; /* Merah muda pas hover */ }

    .slide-meta {
        font-size: 0.95rem; color: rgba(255,255,255,0.85); margin-bottom: 25px;
        display: flex; align-items: center; gap: 10px; font-weight: 500;
    }
    .divider { color: #dc2626; font-weight: bold; }

    /* --- TOMBOL MERAH --- */
    .btn-read-hero {
        display: inline-flex; align-items: center;
        padding: 12px 32px;
        background: #dc2626; /* Merah */
        color: white;
        border-radius: 50px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s;
        box-shadow: 0 4px 15px rgba(220, 38, 38, 0.4);
    }

    .btn-read-hero:hover {
        background: #b91c1c; /* Merah Gelap pas hover */
        transform: translateY(-3px);
    }

    /* --- DOTS --- */
    .slider-dots {
        position: absolute; bottom: 30px; right: 40px;
        display: flex; gap: 10px; z-index: 20;
    }
    .dot {
        width: 10px; height: 10px;
        border-radius: 50%;
        background: rgba(255,255,255,0.3);
        border: none; cursor: pointer; transition: all 0.3s;
    }
    .dot.active {
        background: #dc2626; /* Dot aktif jadi Merah */
        transform: scale(1.3);
    }

    /* --- RESPONSIVE HP --- */
    @media (max-width: 768px) {
        .hero-slider-container { height: 450px; border-radius: 16px; }
        .slide-content-layer { padding: 30px; }
        .slide-title { font-size: 1.6rem; }
        .hero-wrapper.container { padding: 0 15px; margin-top: 20px; }
    }
</style>