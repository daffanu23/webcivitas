---
const WaIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21l1.65-3.8a9 9 0 1 1 3.4 2.9L3 21"/><path d="M9 10a0.5 .5 0 0 0 1 0V9a0.5 .5 0 0 0 -1 0v1a5 5 0 0 0 5 5h1a0.5 .5 0 0 0 0-1h-1a0.5 .5 0 0 0 0 1"/></svg>`;
const MailIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`;

const phoneNumber = "6288228248224"; 
const message = "Halo Tim Media Civitas, saya punya info berita...";
const waLink = `https://wa.me/${phoneNumber}?text=${encodeURIComponent(message)}`;
---

<section class="contact-dual-section">
    <div class="contact-dual-banner">
        
        {/* KOLOM KIRI: WHATSAPP (FAST LANE) */}
        <div class="contact-col left-col">
            <div class="col-content">
                <span class="badge-contact quick">Respon Cepat</span>
                <h3>Punya info berita kilat?</h3>
                <p>Hubungi redaksi via WhatsApp untuk respon instan.</p>
                <a href={waLink} target="_blank" rel="noopener noreferrer" class="btn-contact btn-wa">
                    <span class="icon-box" set:html={WaIcon} />
                    <span>Chat WhatsApp</span>
                </a>
            </div>
        </div>

        {/* GARIS PEMISAH VERTICAL (Hanya di Desktop) */}
        <div class="vertical-divider"></div>

        {/* KOLOM KANAN: EMAIL/FORM (FORMAL LANE) */}
        <div class="contact-col right-col">
            <div class="col-content">
                <span class="badge-contact formal">Bisnis & Kerjasama</span>
                <h3>Ingin mengajukan proposal?</h3>
                <p>Gunakan formulir resmi kami untuk urusan administratif.</p>
                <a href="/contact" class="btn-contact btn-email">
                    <span class="icon-box" set:html={MailIcon} />
                    <span>Hubungi Kami</span>
                </a>
            </div>
        </div>

    </div>
</section>

<style>
    .contact-dual-section {
        padding: 0 0 80px 0; 
        font-family: 'Poppins', sans-serif;
    }

    .contact-dual-banner {
        background-color: var(--bg-light); 
        border: 1px solid var(--border);
        border-radius: 20px;
        display: flex;
        align-items: stretch; /* Agar tinggi kolom sama */
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        overflow: hidden;
        width: 100%;
        box-sizing: border-box;
    }

    :global([data-theme="dark"]) .contact-dual-banner { background-color: #080808; border-color: #1a1a1a; }

    .contact-col {
        flex: 1;
        padding: 50px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        transition: background 0.3s;
    }

    .contact-col:hover {
        background-color: rgba(0,0,0,0.02); /* Efek highlight halus saat hover */
    }
    :global([data-theme="dark"]) .contact-col:hover { background-color: rgba(255,255,255,0.02); }

    .col-content {
        max-width: 400px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
    }

    .vertical-divider {
        width: 1px;
        background-color: var(--border);
        margin: 20px 0; /* Memberi jarak atas bawah sedikit */
    }

    /* TYPOGRAPHY */
    .badge-contact {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-weight: 600;
        padding: 4px 10px;
        border-radius: 4px;
        margin-bottom: 15px;
        display: inline-block;
    }
    .badge-contact.quick { background: rgba(37, 211, 102, 0.1); color: #25D366; }
    .badge-contact.formal { background: rgba(0, 0, 0, 0.05); color: var(--text-muted); }
    :global([data-theme="dark"]) .badge-contact.formal { background: rgba(255, 255, 255, 0.1); }

    h3 { font-size: 1.4rem; font-weight: 600; margin: 0 0 10px 0; color: var(--text); }
    p { font-size: 0.95rem; color: var(--text-muted); margin: 0 0 25px 0; line-height: 1.5; }

    /* BUTTONS */
    .btn-contact {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 12px 28px;
        border-radius: 50px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
        font-size: 0.95rem;
    }

    .btn-wa { background-color: #25D366; color: white; box-shadow: 0 4px 15px rgba(37, 211, 102, 0.2); }
    .btn-wa:hover { background-color: #1ebc57; transform: translateY(-2px); box-shadow: 0 8px 20px rgba(37, 211, 102, 0.3); }

    .btn-email { background-color: var(--text); color: var(--bg); border: 1px solid var(--text); }
    .btn-email:hover { background-color: transparent; color: var(--text); transform: translateY(-2px); }

    .icon-box { display: flex; align-items: center; }

    /* RESPONSIVE */
    @media (max-width: 900px) {
        .contact-dual-banner { flex-direction: column; }
        .vertical-divider { height: 1px; width: 100%; margin: 0; }
        .contact-col { padding: 40px 30px; text-align: center; }
        .col-content { align-items: center; }
    }
</style>