---
import { User, Clock, Calendar } from 'lucide-react'; 
import { Image } from 'astro:assets';

const { article } = Astro.props;

// --- 1. LOGIC WAKTU (Time Ago & Icon Switcher) ---
const getRelativeTimeInfo = (dateString: string) => {
    if (!dateString) return { text: "", isDays: false };
    const date = new Date(dateString);
    const now = new Date();
    const diffInSeconds = Math.floor((now.getTime() - date.getTime()) / 1000);
    
    const minutes = Math.floor(diffInSeconds / 60);
    const hours = Math.floor(diffInSeconds / 3600);
    const days = Math.floor(diffInSeconds / 86400);

    // Jika lebih dari 0 hari, kembalikan teks tanggal dan flag isDays: true
    if (days > 0) return { 
        text: date.toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }), 
        isDays: true 
    };
    if (hours > 0) return { text: `${hours} jam lalu`, isDays: false };
    if (minutes > 0) return { text: `${minutes} mnt lalu`, isDays: false };
    return { text: "Baru saja", isDays: false };
};

// --- 2. LOGIC PEMBERSIH HTML (Strip Tags Kuat) ---
const stripHtml = (html: string) => {
   if (!html) return "";
   
   let text = html.replace(/<\/?[^>]+(>|$)/g, (match) => {
       if (match.match(/<\/(p|div|h[1-6]|li|tr)>/i) || match.match(/<br\s*\/?>/i)) {
           return ' ';
       }
       return ''; 
   });
   
   text = text.replace(/&nbsp;/g, ' ').replace(/&amp;/g, '&').replace(/&quot;/g, '"');
   return text.replace(/\s+/g, ' ').trim();
};

// Data Dummy Fallback
const data = article || {
    title: "Judul Berita Placeholder",
    slug: "#",
    cover_url: "https://placehold.co/600x400?text=No+Image",
    content: "Konten belum tersedia...",
    created_at: new Date().toISOString(),
    profiles: { full_name: "Redaksi" }
};

// --- 3. PROSES EXCERPT ---
const cleanContent = stripHtml(data.content || "");
const excerpt = cleanContent.substring(0, 100) + (cleanContent.length > 100 ? "..." : "");

// 4. Panggil fungsi waktu yang baru
const timeInfo = getRelativeTimeInfo(data.created_at);
---

<a href={`/berita/${data.slug}`} class="news-card">
    
    <div class="card-image">
        {data.cover_url ? (
            <Image 
                src={data.cover_url} 
                alt={data.title} 
                width={400} 
                height={225} 
                format="webp"
                quality="mid"
                loading="lazy" 
            />
        ) : (
            <img src="https://placehold.co/600x400?text=No+Image" alt="Placeholder" />
        )}
    </div>

    <div class="card-content">
        <h3 class="card-title">{data.title}</h3>
        
        <p class="card-excerpt">{excerpt}</p>
        
        <div class="card-meta">
            <div class="meta-item author">
                <User size={14} />
                <span>{data.profiles?.full_name || 'Redaksi'}</span>
            </div>
            <div class="meta-item time">
                {/* LOGIKA IKON DINAMIS */}
                {timeInfo.isDays ? <Calendar size={14} /> : <Clock size={14} />}
                <span>{timeInfo.text}</span>
            </div>
        </div>
    </div>

</a>

<style>
    .news-card {
        display: flex;
        flex-direction: column;
        background: var(--bg-light); 
        text-decoration: none;
        color: inherit;
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
        transition: border-color 0.3s ease, box-shadow 0.3s ease;
        height: 100%; 
    }

    /* AREA GAMBAR */
    .card-image {
        width: 100%;
        height: 180px; 
        border-bottom: 1px solid var(--border);
        overflow: hidden;
        background: var(--bg-light);
    }
    
    .card-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    /* AREA TEKS */
    .card-content {
        padding: 20px;
        display: flex;
        flex-direction: column;
        flex-grow: 1; 
    }

    .card-title {
        font-size: 1.1rem;
        font-weight: 600;
        line-height: 1.4;
        margin-bottom: 10px;
        color: var(--text);
        
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .card-excerpt {
        font-size: 0.9rem;
        color: var(--text-muted);
        margin-bottom: 20px;
        line-height: 1.6;
        
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .card-meta {
        display: flex;
        align-items: center;
        justify-content: space-between; 
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--text-muted);
        padding-top: 15px;
        border-top: 1px dashed var(--border-muted);
        margin-top: auto; 
    }

    .meta-item {
        display: flex;
        align-items: center;
        gap: 6px;
    }
    
    .author { max-width: 60%; }
    .author span { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

    /* ======================================================
       EFEK HOVER EKSKLUSIF PC (DESKTOP ONLY)
       ====================================================== */
    @media (hover: hover) and (pointer: fine) {
        .news-card:hover {
            border-color: var(--text); 
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05); 
        }

        .news-card:hover .card-image img {
            transform: scale(1.05); 
        }
    }
</style>