---
import Layout from '../../layouts/Layout.astro';
import ArticleEditor from '../../components/ArticleEditor'; 
import { getSupabaseServer } from '../../lib/supabase';

// UPGRADE KE getUser()
const supabase = getSupabaseServer(Astro.cookies);
const { data: { user }, error: authError } = await supabase.auth.getUser();

if (authError || !user) {
    return Astro.redirect('/login');
}

const { data: profile } = await supabase
    .from('profiles')
    .select('role')
    .eq('id', user.id)
    .single();

if (!profile || (profile.role !== 'redaksi' && profile.role !== 'admin')) {
    return Astro.redirect('/');
}

const { data: categories } = await supabase.from('categories').select('*').order('name');
const slug = Astro.url.searchParams.get('slug');
let initialArticle = null;
let initialSelectedCategories = [];

if (slug) {
    const { data: article } = await supabase.from('articles').select('*').eq('slug', slug).single();
    if (article) {
        initialArticle = article;
        const { data: pivot } = await supabase.from('article_categories').select('category_id').eq('article_id', article.id);
        if (pivot) {
            initialSelectedCategories = pivot.map(p => p.category_id);
        }
    }
}
---

<Layout title="Tulis Berita | MEDIACIVITAS">
    <div class="container" style="padding-top: 40px;">
        {/* Kita lempar data dari Server langsung ke React! */}
        <ArticleEditor 
            client:only="react" 
            serverUser={user}
            serverCategories={categories || []}
            serverArticle={initialArticle}
            serverSelectedCategories={initialSelectedCategories}
        />
    </div>
</Layout>