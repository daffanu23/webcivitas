---
import Layout from '../layouts/Layout.astro';
import HeroSlider from '../components/HeroSlider.astro'; 
import SubNewsCard from '../components/SubNewsCard.astro'; 
import MagazinePromo from '../components/MagazinePromo.astro'; // <-- 1. IMPORT PROMO MAJALAH
import { supabase } from '../lib/supabase';
import CategoryNav from '../components/CategoryNav.astro';
import InstagramPromo from '../components/InstagramPromo.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';

const activeCat = Astro.url.searchParams.get('kategori') || '';

// --- LOGIKA FETCH BERITA ---
let query = supabase
  .from('articles')
  .select(`
    id, title, slug, created_at, cover_url, content,
    profiles ( full_name ),
    categories ( slug )
  `)
  .eq('status', 'published')
  .order('created_at', { ascending: false });

// Kita ambil data agak banyak untuk stok grid
const { data: allArticles, error } = await query.limit(20);
if (error) console.error("Error fetch news:", error);

// Filter Manual Kategori
let filteredArticles = allArticles || [];

if (activeCat) {
    filteredArticles = filteredArticles.filter(a => {
        const cats = a.categories;
        if (Array.isArray(cats)) {
            return cats.some((c: any) => c.slug === activeCat);
        }
        return (cats as any)?.slug === activeCat;
    });
}

// Logika Tampilan Grid
let gridArticles = [];

if (activeCat) {
    gridArticles = filteredArticles;
} else {
    // Ambil berita ke-6 sampai ke-14 (9 item)
    gridArticles = filteredArticles.slice(5, 14); 
}
---

<Layout title="MEDIACIVITAS - Berita Terkini">

    <div id="hero-slider-section">
        <HeroSlider />
    </div>

    <MagazinePromo />

    <div class="section-latest container">
        
        <CategoryNav activeSlug={activeCat} />
        
        <div id="dynamic-grid-container">
            {gridArticles.length > 0 ? (
                <>
                    <h3 class="section-label">
                        {activeCat ? `Berita Kategori: ${activeCat}` : 'Berita Terbaru Lainnya'}
                    </h3>
                    <div class="news-grid">
                        {gridArticles.map((item) => (
                            <div class="grid-item">
                                <SubNewsCard article={item} />
                            </div>
                        ))}
                    </div>
                </>
            ) : (
                <div style="text-align: center; padding: 60px 0; color: var(--text-muted);">
                    <p>Belum ada berita lain untuk ditampilkan.</p>
                </div>
            )}
            
            {/* TOMBOL ARSIP */}
            <div class="center-btn">
                <a href={`/arsip${activeCat ? '?kategori=' + activeCat : ''}`} class="btn-archive-minimal">
                    <span>Lihat Arsip Lengkap</span>
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 12h14"></path>
                        <path d="m12 5 7 7-7 7"></path>
                    </svg>
                </a>
            </div>
        </div>

    </div>
    
    <div class="container">
        <InstagramPromo />
    </div>
    
    <WhatsAppButton />
</Layout>

<style>
    /* Layout Container Global */
    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 20px;
    }

    /* Section Hero Slider */
    #hero-slider-section {
        margin-bottom: 0px; /* Disesuaikan agar mepet dengan Magazine Promo */
        /* Full width background handled by component */
    }
    
    /* Section Berita Grid */
    .section-latest { margin-bottom: 80px; margin-top: 50px; }
    
    .section-label {
        font-size: 1.2rem;
        font-weight: 700;
        margin-bottom: 25px;
        padding-bottom: 15px;
        border-bottom: 1px solid var(--border);
        text-transform: capitalize;
    }

    .news-grid { 
        display: grid; 
        grid-template-columns: repeat(3, 1fr); 
        gap: 30px; 
        margin-bottom: 40px; 
    }
    
    /* TOMBOL ARSIP MINIMALIS */
    .center-btn { text-align: center; margin-top: 20px; }
    .btn-archive-minimal {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 12px 25px;
        color: var(--text);
        font-weight: 500;
        font-size: 0.95rem;
        transition: all 0.3s ease;
        text-decoration: none;
        border: 1px solid var(--border);
        border-radius: 50px;
    }
    
    .btn-archive-minimal svg { 
        transition: transform 0.3s ease; 
    }
    
    .btn-archive-minimal:hover {
        border-color: var(--text);
        background: var(--bg-light);
    }
    
    .btn-archive-minimal:hover svg {
        transform: translateX(4px);
    }

    @media (max-width: 900px) { .news-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 600px) { .news-grid { grid-template-columns: 1fr; } }
</style>