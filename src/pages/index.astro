---
import Layout from '../layouts/Layout.astro';
import HeroNews from '../components/HeroNews.astro';
import SubNewsCard from '../components/SubNewsCard.astro'; 
import { supabase } from '../lib/supabase';
import CategoryNav from '../components/CategoryNav.astro';

// 1. Tangkap parameter kategori
const activeCat = Astro.url.searchParams.get('kategori') || '';

// 2. Siapkan Query Database
let selectQuery = `
  id, title, slug, created_at, cover_url, content,
  profiles ( full_name ),
  categories ( slug )
`;

if (activeCat) {
    selectQuery = `
      id, title, slug, created_at, cover_url, content,
      profiles ( full_name ),
      categories!inner ( slug )
    `;
}

let query = supabase
  .from('articles')
  .select(selectQuery)
  .eq('status', 'published')
  .order('created_at', { ascending: false });

if (activeCat) {
    query = query.eq('categories.slug', activeCat);
}

const { data: articles, error } = await query.limit(7);
if (error) console.error("Error fetch news:", error);

// 3. Pisahkan Data
const heroArticle = articles && articles.length > 0 ? articles[0] : null;
const subArticles = articles && articles.length > 1 ? articles.slice(1) : [];
---

<Layout title="MEDIACIVITAS - Berita Terkini">

    {/* WADAH 1: HERO. Dibungkus div dengan ID statis agar mudah ditukar JS */}
    <div id="dynamic-hero-container">
        {heroArticle && (
            <div class="section-hero">
                <HeroNews article={heroArticle} />
            </div>
        )}
    </div>

    <div class="section-latest">
        <CategoryNav activeSlug={activeCat} />
        
        {/* WADAH 2: GRID & TOMBOL ARSIP. */}
        <div id="dynamic-grid-container">
            {subArticles.length > 0 ? (
                <div class="news-grid">
                    {subArticles.map((item) => (
                        <div class="grid-item">
                            <SubNewsCard article={item} />
                        </div>
                    ))}
                </div>
            ) : (
                <div style="text-align: center; padding: 40px 0; color: var(--text-muted);">
                    <p>{heroArticle ? "Belum ada berita lain untuk kategori ini." : "Belum ada berita sama sekali di kategori ini."}</p>
                </div>
            )}
            
            <div class="center-btn">
                <a href={`/arsip${activeCat ? '?kategori=' + activeCat : ''}`} class="btn-archive">
                    {activeCat ? 'Lihat Semua Arsip Kategori Ini →' : 'Lihat Semua Arsip Berita →'}
                </a>
            </div>
        </div>

    </div>

</Layout>

<style>
    /* STYLE TETAP SAMA SEPERTI SEBELUMNYA */
    .section-hero { margin-top: 20px; margin-bottom: 60px; }
    .section-latest { margin-bottom: 100px; }
    .news-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px; margin-bottom: 60px; }
    .center-btn { text-align: center; }
    .btn-archive {
        display: inline-block; padding: 15px 40px; background: #111; color: #fff;
        font-weight: 700; border-radius: 50px; transition: transform 0.2s, background 0.2s; text-decoration: none;
    }
    :global([data-theme="dark"]) .btn-archive { background: var(--bg-light); color: var(--text); border: 1px solid var(--border); }
    .btn-archive:hover { background: #333; transform: scale(1.05); }
    :global([data-theme="dark"]) .btn-archive:hover { background: var(--border); }
    @media (max-width: 900px) { .news-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 600px) { .news-grid { grid-template-columns: 1fr; } }
</style>