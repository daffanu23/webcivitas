---
import Layout from '../layouts/Layout.astro';
import HeroNews from '../components/HeroNews.astro';
import SubNewsCard from '../components/SubNewsCard.astro'; 
import { supabase } from '../lib/supabase';
import CategoryNav from '../components/CategoryNav.astro';
import InstagramPromo from '../components/InstagramPromo.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';

const activeCat = Astro.url.searchParams.get('kategori') || '';

let selectQuery = `
  id, title, slug, created_at, cover_url, content,
  profiles ( full_name ),
  categories ( slug )
`;

if (activeCat) {
    selectQuery = `
      id, title, slug, created_at, cover_url, content,
      profiles ( full_name ),
      categories!inner ( slug )
    `;
}

let query = supabase
  .from('articles')
  .select(selectQuery)
  .eq('status', 'published')
  .order('created_at', { ascending: false });

if (activeCat) {
    query = query.eq('categories.slug', activeCat);
}

const { data: articles, error } = await query.limit(7);
if (error) console.error("Error fetch news:", error);

const heroArticle = articles && articles.length > 0 ? articles[0] : null;
const subArticles = articles && articles.length > 1 ? articles.slice(1) : [];
---

<Layout title="MEDIACIVITAS - Berita Terkini">

    <div id="dynamic-hero-container">
        {heroArticle && (
            <div class="section-hero">
                <HeroNews article={heroArticle} />
            </div>
        )}
    </div>

    <div class="section-latest">
        <CategoryNav activeSlug={activeCat} />
        
        <div id="dynamic-grid-container">
            {subArticles.length > 0 ? (
                <div class="news-grid">
                    {subArticles.map((item) => (
                        <div class="grid-item">
                            <SubNewsCard article={item} />
                        </div>
                    ))}
                </div>
            ) : (
                <div style="text-align: center; padding: 40px 0; color: var(--text-muted);">
                    <p>{heroArticle ? "Belum ada berita lain untuk kategori ini." : "Belum ada berita sama sekali di kategori ini."}</p>
                </div>
            )}
            
            {/* DESAIN TOMBOL ARSIP MINIMALIS */}
            <div class="center-btn">
                <a href={`/arsip${activeCat ? '?kategori=' + activeCat : ''}`} class="btn-archive-minimal">
                    <span>{activeCat ? 'Lihat Arsip Kategori Ini' : 'Lihat Semua Arsip'}</span>
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 12h14"></path>
                        <path d="m12 5 7 7-7 7"></path>
                    </svg>
                </a>
            </div>
        </div>

    </div>
    
    <InstagramPromo />
    <WhatsAppButton />
</Layout>

<style>
    .section-hero { margin-top: 20px; margin-bottom: 60px; }
    
    /* REVISI GAP: Margin dikurangi drastis agar IG Promo merapat */
    .section-latest { margin-bottom: 40px; } 
    .news-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px; margin-bottom: 30px; }
    
    /* STYLE TOMBOL ARSIP MINIMALIS */
    .center-btn { text-align: center; }
    .btn-archive-minimal {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        color: var(--text-muted);
        font-weight: 400; /* Medium-Light */
        font-size: 0.95rem;
        transition: color 0.3s ease;
        text-decoration: none;
    }
    
    .btn-archive-minimal svg { 
        transition: transform 0.3s ease; 
        color: var(--text-muted);
    }
    
    .btn-archive-minimal:hover {
        color: var(--text);
    }
    
    .btn-archive-minimal:hover svg {
        color: var(--text);
        transform: translateX(5px);
    }

    @media (max-width: 900px) { .news-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 600px) { .news-grid { grid-template-columns: 1fr; } }
</style>