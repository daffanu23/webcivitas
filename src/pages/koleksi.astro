---
import Layout from '../layouts/Layout.astro';
import { Bookmark } from 'lucide-react';
import { getSupabaseServer } from '../lib/supabase';
import SubNewsCard from '../components/SubNewsCard.astro';

// UPGRADE KE getUser()
const supabase = getSupabaseServer(Astro.cookies);
const { data: { user }, error: authError } = await supabase.auth.getUser();

if (authError || !user) {
    return Astro.redirect('/login');
}

const { data: bookmarks } = await supabase
    .from('bookmarks')
    .select(`
        created_at,
        articles (
            id, title, slug, content, cover_url, created_at,
            profiles ( full_name )
        )
    `)
    .eq('user_id', user.id)
    .order('created_at', { ascending: false });

const savedArticles = bookmarks?.map((b: any) => {
    return Array.isArray(b.articles) ? b.articles[0] : b.articles;
}).filter(Boolean) || [];
---

<Layout title="Koleksi Saya | MEDIACIVITAS">
    <div class="container page-wrapper">
        
        <div class="page-header">
            <Bookmark size={32} strokeWidth={1.5} />
            <h1>Koleksi Bacaan</h1>
        </div>

        {savedArticles.length === 0 ? (
            <div class="state-box">
                <p>Belum ada artikel yang Anda simpan.</p>
                <a href="/" class="btn-home">Eksplorasi Berita</a>
            </div>
        ) : (
            <div class="news-grid">
                {savedArticles.map((article: any) => (
                    <div class="grid-item">
                        {/* KARTU LANGSUNG DIPANGGIL DARI KOMPONEN ASLINYA! */}
                        <SubNewsCard article={article} />
                    </div>
                ))}
            </div>
        )}

    </div>
</Layout>

<style>
    .page-wrapper { padding-top: 60px; padding-bottom: 100px; min-height: 80vh; }
    .page-header { display: flex; align-items: center; gap: 15px; margin-bottom: 40px; padding-bottom: 20px; border-bottom: 2px solid var(--border); color: var(--text); }
    .page-header h1 { font-size: 2rem; font-weight: 800; margin: 0; }
    .state-box { text-align: center; padding: 60px 0; color: var(--text-muted); }
    .btn-home { display: inline-block; margin-top: 20px; padding: 10px 24px; background: var(--text); color: var(--bg); border-radius: 50px; font-weight: 600; text-decoration: none; transition: transform 0.2s; }
    .btn-home:hover { transform: scale(1.05); }
    .news-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 30px; margin-bottom: 60px; }
</style>