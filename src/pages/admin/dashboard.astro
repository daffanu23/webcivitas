---
import Layout from '../../layouts/Layout.astro';
import AdminPanel from '../../components/AdminPanel'; 
import { getSupabaseServer } from '../../lib/supabase';

const supabase = getSupabaseServer(Astro.cookies);

// 1. Cek User Login
const { data: { user }, error: authError } = await supabase.auth.getUser();

if (authError || !user) {
    return Astro.redirect('/login');
}

// 2. Cek Role Admin
const { data: profile } = await supabase
    .from('profiles')
    .select('role')
    .eq('id', user.id)
    .single();

if (!profile || profile.role !== 'admin') {
    return Astro.redirect('/'); 
}

// 3. Ambil Data Awal
const { data: categories } = await supabase.from('categories').select('*').order('name');
const { data: articles } = await supabase
    .from('articles')
    .select('*, profiles(full_name), article_categories(category_id)')
    .order('created_at', { ascending: false }); 
---

<Layout title="Admin Panel | MEDIACIVITAS">
    <div class="admin-page-wrapper">
        <AdminPanel 
            client:only="react" 
            serverCategories={categories || []} 
            serverArticles={articles || []}
            userId={user.id}
        />
    </div>
</Layout>

<style is:global>
    /* Biarkan Navbar global tetap muncul */
    body {
        background-color: var(--bg);
    }

    /* Sesuaikan padding agar tidak tertutup Navbar sticky */
    .admin-page-wrapper {
        min-height: 100vh;
    }
</style>